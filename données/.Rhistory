library(phyloseq)
library(ggplot2)
phyloseq_lot <- readRDS("donnees_nettoyees.rds")
plant_df <- data.frame(
project = sample_data(phyloseq_lot)$project,
sample = sample_names(phyloseq_lot),
organ = sample_data(phyloseq_lot)$organ,
plant_genus = sample_data(phyloseq_lot)$plant_genus,
plant_family = sample_data(phyloseq_lot)$plant_family,
plant_species = sample_data(phyloseq_lot)$plant_species,
row.names = NULL
)
# Calcul de la richesse spécifique (Observed) pour chaque échantillon
div_alpha <- estimate_richness(phyloseq_lot, measures = c("Observed", "Chao1", "Shannon", "Simpson"))
div_alpha$sample <- rownames(div_alpha)
div_alpha$project = plant_df$project[match(div_alpha$sample, plant_df$sample)]
# Fusion des données de diversité alpha avec les métadonnées
div_alpha <- merge(div_alpha, plant_df, by = "sample")
